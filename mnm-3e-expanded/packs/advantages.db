{"name":"Accurate Attack","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>When you make an accurate attack, you can take a penalty of up to –5 on the effect modifier of the attack and add the same number (up to +5) to your attack bonus.</p>","equipement":false,"rang":1,"edit":true,"listEffectsVariantes":{}},"effects":[],"_id":"2yefowshqb2"}
