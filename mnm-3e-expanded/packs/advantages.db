{"_id":"kr8ykksona8","name":"Animal Empathy","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>You have a special connection with animals. You can use interaction skills on animals normally.</p>","rang":1},"effects":[{"name":"Animal Empathy Bonus","changes":[{"key":"system.competence.persuasion.bonuses","mode":2,"value":"2","priority":20}],"disabled":false,"transfer":true,"icon":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg"}],"flags":{}}
