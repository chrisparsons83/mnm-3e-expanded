{"_id":"29puudv47wl","name":"Attractive","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>+2 circumstance bonus on Deception and Persuasion checks (+5 for rank 2).</p>","rang":1},"effects":[],"flags":{}}
