{"_id":"chjhlk1g558","name":"Evasion","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>+2 circumstance bonus to Dodge checks to avoid area effects. Rank 2 increases bonus to +5.</p>","rang":2},"effects":[{"name":"Evasion Bonus","changes":[{"key":"system.defense.esquive.bonuses","mode":2,"value":"2","priority":20}],"disabled":false,"transfer":true,"icon":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg"}]}
{"_id":"m240ksu2d1","name":"Attractive","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>+2 circumstance bonus on Deception and Persuasion checks (+5 for rank 2).</p>","rang":1},"effects":[{"name":"Attractive Bonus","changes":[{"key":"system.competence.duperie.bonuses","mode":2,"value":"2","priority":20}],"disabled":false,"transfer":true,"icon":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg"}]}
{"_id":"ijnx77osvu","name":"Eidetic Memory","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>Perfect recall. +5 circumstance bonus on memory checks. Can make Expertise checks as if trained.</p>","rang":1},"effects":[{"name":"Eidetic Memory Bonus","changes":[{"key":"system.competence.investigation.bonuses","mode":2,"value":"5","priority":20}],"disabled":false,"transfer":true,"icon":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg"}]}
{"_id":"zt8jw396mna","name":"Animal Empathy","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>You have a special connection with animals. You can use interaction skills on animals normally.</p>","rang":1},"effects":[{"name":"Animal Empathy Bonus","changes":[{"key":"system.competence.persuasion.bonuses","mode":2,"value":"2","priority":20}],"disabled":false,"transfer":true,"icon":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg"}]}
