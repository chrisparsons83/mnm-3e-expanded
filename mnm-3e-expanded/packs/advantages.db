{"_id":"zbjmh1a8jj","name":"Attractive","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>+2 circumstance bonus on Deception and Persuasion checks (+5 for rank 2).</p>","rang":1},"effects":[],"flags":{}}
{"_id":"87tw4fen1qo","name":"Eidetic Memory","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>Perfect recall. +5 circumstance bonus on memory checks. Can make Expertise checks as if trained.</p>","rang":1},"effects":[],"flags":{}}
