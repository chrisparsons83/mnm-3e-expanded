{"_id":"urp1b70cmyn","ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"exportSource":null,"coreVersion":"13.350","systemId":"mutants-and-masterminds-3e","systemVersion":"1.39.13"},"name":"Summon","type":"pouvoir","img":"systems/mutants-and-masterminds-3e/assets/icons/pouvoir.svg","system":{"activate":true,"special":"simple","type":"generaux","action":"simple","portee":"contact","duree":"prolonge","effets":"<h3>Description</h3><p>You can call an independent character to your side.</p><h3>Mechanics</h3><p>Summoned minion has (rank x 15) power points.</p>","notes":"You can call an independent character to your side.","extras":{},"defauts":{},"cout":{"rang":1,"parrang":2,"total":0,"rangDyn":0,"rangDynMax":0,"divers":0,"modrang":0,"modfixe":0,"totalTheorique":0,"parrangtotal":"0"}}}
{"_id":"um2a36u4mlk","ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"exportSource":null,"coreVersion":"13.350","systemId":"mutants-and-masterminds-3e","systemVersion":"1.39.13"},"name":"Swimming","type":"pouvoir","img":"systems/mutants-and-masterminds-3e/assets/icons/pouvoir.svg","system":{"activate":true,"special":"libre","type":"generaux","action":"libre","portee":"personnelle","duree":"prolonge","effets":"<h3>Description</h3><p>You can move through the water faster than normal.</p><h3>Mechanics</h3><p>Water speed rank equals effect rank.</p>","notes":"You can move through the water faster than normal.","extras":{},"defauts":{},"cout":{"rang":1,"parrang":1,"total":0,"rangDyn":0,"rangDynMax":0,"divers":0,"modrang":0,"modfixe":0,"totalTheorique":0,"parrangtotal":"0"}}}
{"_id":"n44thfm53ua","ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"exportSource":null,"coreVersion":"13.350","systemId":"mutants-and-masterminds-3e","systemVersion":"1.39.13"},"name":"Telekinesis","type":"pouvoir","img":"systems/mutants-and-masterminds-3e/assets/icons/pouvoir.svg","system":{"activate":true,"special":"simple","type":"generaux","action":"simple","portee":"distance","duree":"prolonge","effets":"<h3>Description</h3><p>You can move objects at a distance with your mind.</p><h3>Mechanics</h3><p>Equivalent to Move Object power.</p>","notes":"You can move objects at a distance with your mind.","extras":{"1":{"name":"Precise","data":{"description":"<p>You can use a Precise effect to perform tasks requiring delicacy and fine control.</p><p>Flat 1 point.</p>","cout":{"fixe":true,"rang":false,"value":1}},"details":true}},"defauts":{},"cout":{"rang":1,"parrang":2,"total":0,"rangDyn":0,"rangDynMax":0,"divers":0,"modrang":0,"modfixe":0,"totalTheorique":0,"parrangtotal":"0"}}}
{"_id":"4flrz4sqxmp","ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"exportSource":null,"coreVersion":"13.350","systemId":"mutants-and-masterminds-3e","systemVersion":"1.39.13"},"name":"Telepathy","type":"pouvoir","img":"systems/mutants-and-masterminds-3e/assets/icons/pouvoir.svg","system":{"activate":true,"special":"simple","type":"generaux","action":"simple","portee":"perception","duree":"prolonge","effets":"<h3>Description</h3><p>You can communicate mentally and read minds.</p><h3>Mechanics</h3><p>Combination of Mind Reading and Communication (Mental).</p>","notes":"You can communicate mentally and read minds.","extras":{},"defauts":{},"cout":{"rang":1,"parrang":2,"total":0,"rangDyn":0,"rangDynMax":0,"divers":0,"modrang":0,"modfixe":0,"totalTheorique":0,"parrangtotal":"0"}}}
{"_id":"kf4465naym","ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"exportSource":null,"coreVersion":"13.350","systemId":"mutants-and-masterminds-3e","systemVersion":"1.39.13"},"name":"Teleport","type":"pouvoir","img":"systems/mutants-and-masterminds-3e/assets/icons/pouvoir.svg","system":{"activate":true,"special":"mouvement","type":"generaux","action":"mouvement","portee":"personnelle","duree":"instantane","effets":"<h3>Description</h3><p>You can move instantly from one point to another.</p><h3>Mechanics</h3><p>Rank 1 = 60ft, Rank 10 = 1000 miles.</p>","notes":"You can move instantly from one point to another.","extras":{"1":{"name":"Accurate","data":{"description":"<p>An effect with this extra is especially accurate; you get +2 per Accurate rank to attack checks made with it.</p><p>Flat 1 point per rank.</p>","cout":{"fixe":true,"rang":true,"value":1}},"details":true}},"defauts":{},"cout":{"rang":1,"parrang":2,"total":0,"rangDyn":0,"rangDynMax":0,"divers":0,"modrang":0,"modfixe":0,"totalTheorique":0,"parrangtotal":"0"}}}
{"_id":"j1nqnlk776","ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"exportSource":null,"coreVersion":"13.350","systemId":"mutants-and-masterminds-3e","systemVersion":"1.39.13"},"name":"Transform","type":"pouvoir","img":"systems/mutants-and-masterminds-3e/assets/icons/pouvoir.svg","system":{"activate":true,"special":"simple","type":"generaux","action":"simple","portee":"contact","duree":"continu","effets":"<h3>Description</h3><p>You can change one type of thing into another.</p><h3>Mechanics</h3><p>Rank 1 transforms 1 lb. Rank 10 transforms 400 lbs.</p>","notes":"You can change one type of thing into another.","extras":{"1":{"name":"Increased Mass","data":{"description":"<p>Each rank of this extra increases the mass rank you can carry or move with the effect by 1.</p><p>Flat 1 point per rank.</p>","cout":{"fixe":true,"rang":true,"value":1}},"details":true}},"defauts":{},"cout":{"rang":1,"parrang":2,"total":0,"rangDyn":0,"rangDynMax":0,"divers":0,"modrang":0,"modfixe":0,"totalTheorique":0,"parrangtotal":"0"}}}
{"_id":"7nvja43tnzr","ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"exportSource":null,"coreVersion":"13.350","systemId":"mutants-and-masterminds-3e","systemVersion":"1.39.13"},"name":"Variable","type":"pouvoir","img":"systems/mutants-and-masterminds-3e/assets/icons/pouvoir.svg","system":{"activate":true,"special":"simple","type":"generaux","action":"simple","portee":"personnelle","duree":"prolonge","effets":"<h3>Description</h3><p>You can change your traits at will to suit your needs.</p><h3>Mechanics</h3><p>Allocate (rank x 5) power points to any traits fitting descriptors.</p>","notes":"You can change your traits at will to suit your needs.","extras":{"1":{"name":"Affects Others","data":{"description":"<p>This extra allows you to give someone else use of a personal effect. You must touch the subject as a standard action, and they have control over their use of the effect.</p><p>+0 or +1 cost per rank.</p>","cout":{"fixe":false,"rang":true,"value":1}},"details":true}},"defauts":{},"cout":{"rang":1,"parrang":7,"total":0,"rangDyn":0,"rangDynMax":0,"divers":0,"modrang":0,"modfixe":0,"totalTheorique":0,"parrangtotal":"0"}}}
{"_id":"21o4194y7k6","ownership":{"default":0},"_stats":{"compendiumSource":null,"duplicateSource":null,"exportSource":null,"coreVersion":"13.350","systemId":"mutants-and-masterminds-3e","systemVersion":"1.39.13"},"name":"Weather Control","type":"pouvoir","img":"systems/mutants-and-masterminds-3e/assets/icons/pouvoir.svg","system":{"activate":true,"special":"simple","type":"generaux","action":"simple","portee":"perception","duree":"prolonge","effets":"<h3>Description</h3><p>You can manipulate the weather in your area.</p><h3>Mechanics</h3><p>Environment effect (Cold, Heat, Impede Movement, Visibility).</p>","notes":"You can manipulate the weather in your area.","extras":{},"defauts":{},"cout":{"rang":1,"parrang":2,"total":0,"rangDyn":0,"rangDynMax":0,"divers":0,"modrang":0,"modfixe":0,"totalTheorique":0,"parrangtotal":"0"}}}